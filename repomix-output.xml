  <script>
    // Mobile menu toggle
    document.querySelector('.mobile-menu')
      .addEventListener('click', () => document.querySelector('.nav-right').classList.toggle('show'));

    // Image error fallback
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('img').forEach(img => {
        img.onerror = function(){
          const altText = this.alt || 'Image';
          const fallback = document.createElement('div');
          fallback.className = 'img-fallback';
          fallback.textContent = altText;
          this.parentNode.replaceChild(fallback, this);
          console.error('Failed to load image:', this.src);
        }
      });
      
      // Navigation bar scroll behavior
      const nav = document.querySelector('nav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      });
      if (window.scrollY > 50) {
        nav.classList.add('scrolled');
      }
    });

    // 画像モーダル制御関数 - Enhanced
    function openImageModal(imgElement, trackingType = 'venue_map') {
      const modal = document.getElementById('imageModal');
      const modalImg = document.getElementById('modalImage');
      
      // モーダル画像の設定
      modalImg.src = imgElement.src;
      modalImg.alt = imgElement.alt;
      
      // モーダル表示
      modal.classList.add('show');
      modal.setAttribute('aria-hidden', 'false');
      
      // フォーカス管理
      const closeButton = modal.querySelector('.image-modal-close');
      closeButton.focus();
      
      // ボディスクロール無効化
      document.body.style.overflow = 'hidden';
      
      // アクセシビリティ: 背景のフォーカス可能要素を無効化
      trapFocus(modal);
      
      // Analytics tracking - Enhanced
      if (trackingType === 'venue_map') {
        trackVenueMapClick();
      } else if (trackingType === 'ichiju-sansai' || trackingType === 'teeraum') {
        // Menu tracking is handled separately in onclick
      }
    }

    function closeImageModal() {
      const modal = document.getElementById('imageModal');
      
      // モーダル非表示
      modal.classList.remove('show');
      modal.setAttribute('aria-hidden', 'true');
      
      // ボディスクロール復元
      document.body.style.overflow = '';
      
      // フォーカス復元
      const venueMapImg = document.querySelector('.venue-map-img');
      if (venueMapImg) {
        venueMapImg.focus();
      }
    }

    function handleImageKeyDown(event, imgElement) {
      // Enterキーまたはスペースキーで画像を開く
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        
        // Analytics tracking based on image source
        if (imgElement.src.includes('ICHIJU-SANSAI_menu')) {
          openImageModal(imgElement, 'ichiju-sansai');
          trackMenuClick('ichiju-sansai');
        } else if (imgElement.src.includes('Teeraum_menu')) {
          openImageModal(imgElement, 'teeraum');
          trackMenuClick('teeraum');
        } else {
          openImageModal(imgElement, 'venue_map');
        }
      }
    }

    // フォーカストラップ機能
    function trapFocus(modalElement) {
      const focusableElements = modalElement.querySelectorAll(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      const firstElement = focusableElements[0];
      const lastElement = focusableElements[focusableElements.length - 1];

      function handleTabKey(event) {
        if (event.key === 'Tab') {
          if (event.shiftKey) {
            if (document.activeElement === firstElement) {
              event.preventDefault();
              lastElement.focus();
            }
          } else {
            if (document.activeElement === lastElement) {
              event.preventDefault();
              firstElement.focus();
            }
          }
        }
      }

      modalElement.addEventListener('keydown', handleTabKey);
      
      // リスナーのクリーンアップ関数を返す
      return () => {
        modalElement.removeEventListener('keydown', handleTabKey);
      };
    }

    // ESCキーでモーダルを閉じる
    document.addEventListener('keydown', function(event) {
      const modal = document.getElementById('imageModal');
      if (event.key === 'Escape' && modal.classList.contains('show')) {
        closeImageModal();
      }
    });

    // パフォーマンス監視 (optional)
    if ('performance' in window) {
      window.addEventListener('load', function() {
        setTimeout(function() {
          const perfData = performance.getEntriesByType('navigation')[0];
          console.log('Page load time:', perfData.loadEventEnd - perfData.fetchStart, 'ms');
        }, 0);
      });
    }
  </script>
</body>
